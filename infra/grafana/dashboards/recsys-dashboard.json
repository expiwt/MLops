{
  "title": "RecSys API",
  "uid": "recsys-api",
  "schemaVersion": 39,
  "version": 4,
  "timezone": "browser",
  "panels": [
    {
      "title": " RPS",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(recsys_requests_total[$__rate_interval]))",
          "legendFormat": "total"
        }
      ]
    },
    {
      "title": " Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(recsys_request_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(recsys_request_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(recsys_request_latency_seconds_bucket[$__rate_interval])) by (le))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "title": " HTTP Status Codes",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(recsys_requests_total{status=~\"2..\"}[$__rate_interval]))",
          "legendFormat": "2xx "
        },
        {
          "expr": "sum(rate(recsys_requests_total{status=~\"4..\"}[$__rate_interval]))",
          "legendFormat": "4xx "
        },
        {
          "expr": "sum(rate(recsys_requests_total{status=~\"5..\"}[$__rate_interval]))",
          "legendFormat": "5xx "
        }
      ]
    },
    {
      "title": " Predictions by Model",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(recsys_predictions_total{model_type=\"popular\"}[$__rate_interval]))",
          "legendFormat": "popular"
        },
        {
          "expr": "sum(rate(recsys_predictions_total{model_type=\"tfidf\"}[$__rate_interval]))",
          "legendFormat": "tfidf"
        }
      ]
    },
    {
      "title": " Model Metrics — Popular",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {}
      },
      "targets": [
        {
          "expr": "recsys_model_metric{model_type=\"popular\", metric=\"MAP_10\"}",
          "legendFormat": "MAP@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"popular\", metric=\"Precision_10\"}",
          "legendFormat": "Precision@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"popular\", metric=\"Recall_10\"}",
          "legendFormat": "Recall@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"popular\", metric=\"Novelty_10\"}",
          "legendFormat": "Novelty@10"
        }
      ]
    },
    {
      "title": " Model Metrics — TF-IDF",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "fieldConfig": {
        "defaults": {}
      },
      "targets": [
        {
          "expr": "recsys_model_metric{model_type=\"tfidf\", metric=\"MAP_10\"}",
          "legendFormat": "MAP@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"tfidf\", metric=\"Precision_10\"}",
          "legendFormat": "Precision@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"tfidf\", metric=\"Recall_10\"}",
          "legendFormat": "Recall@10"
        },
        {
          "expr": "recsys_model_metric{model_type=\"tfidf\", metric=\"Novelty_10\"}",
          "legendFormat": "Novelty@10"
        }
      ]
    }
  ]
}
